generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DOCTOR
  PATIENT
}

enum SchedulingType {
  STREAM
  WAVE
}

model User {
  id                    String                  @id @default(uuid())
  name                  String
  email                 String                  @unique
  password              String
  role                  Role
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  doctorProfile         DoctorProfile?
  patientProfile        PatientProfile?
  recurringAvailability RecurringAvailability[] @relation("DoctorRecurring")
  customAvailability    CustomAvailability[]    @relation("DoctorCustom")
  doctorAppointments    Appointment[]           @relation("DoctorAppointments")
  patientAppointments   Appointment[]           @relation("PatientAppointments")
  patientNotifications  Notification[]          @relation("PatientNotifications")
}

model DoctorProfile {
  id                   String         @id @default(uuid())
  userId               String         @unique
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName             String
  specialization       String
  experience           Int
  qualification        String
  consultationFee      Int
  slotDuration         Int            @default(15) // Configurable slot duration in minutes
  schedulingType       SchedulingType @default(STREAM)
  bufferTime           Int            @default(0)  // Buffer time between slots (STREAM)
  waveCapacity         Int            @default(5)  // Max patients per wave (WAVE)
  searchWindow         Int            @default(30) // Max working days to search for next available slot
  allowFutureBooking   Boolean        @default(false) // If true, patients can book future appointments
  maxFutureBookingDays Int?                           // Max days ahead; null = default 7 days
  availability         String
  isAvailable          Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model PatientProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName        String
  age             Int
  gender          String
  contactDetails  String
  basicHealthInfo String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model RecurringAvailability {
  id        String    @id @default(uuid())
  doctorId  String
  doctor    User      @relation("DoctorRecurring", fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek DayOfWeek
  startTime String    // e.g. "09:00"
  endTime   String    // e.g. "13:00"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CustomAvailability {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    User     @relation("DoctorCustom", fields: [doctorId], references: [id], onDelete: Cascade)
  date      DateTime // specific date override
  startTime String   // e.g. "14:00"
  endTime   String   // e.g. "16:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id        String            @id @default(uuid())
  doctorId  String
  patientId String
  doctor    User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient   User              @relation("PatientAppointments", fields: [patientId], references: [id])
  date        DateTime
  startTime   String
  endTime     String
  tokenNumber Int?              // Assigned for WAVE scheduling
  status      AppointmentStatus @default(SCHEDULED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_REMINDER
  FOLLOW_UP_REMINDER
}

model Notification {
  id        String           @id @default(uuid())
  patientId String
  patient   User             @relation("PatientNotifications", fields: [patientId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}
